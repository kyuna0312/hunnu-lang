// std/fs.hn - Filesystem functions for Hunnu

// Check if file exists
fn exists(path) {
    let content = __hn_fs_read_file(path)
    return content != ""
}

// Read entire file content
fn read_file(path) {
    return __hn_fs_read_file(path)
}

// Write content to file
fn write_file(path, content) {
    return __hn_fs_write_file(path, content)
}
