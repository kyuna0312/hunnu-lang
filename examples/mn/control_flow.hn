функц main() {
    хувьсагч x = 10
    хэрвээ x > 5 {
        хэвлэх("Том байна")
    } бусад {
        хэвлэх("Жижиг байна")
    }
    хувьсагч өөрчлөгдөх i = 0
    давталт i < 5 {
        хэвлэх(i)
        i = i + 1
    }
    тооллого хувьсагч өөрчлөгдөх j = 0; j < 3; j = j + 1 {
        хэвлэх(j)
    }
}
